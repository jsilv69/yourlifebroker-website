# Copy to .env for local dev:  cp .env.example .env
# In production these are set as Fly secrets, NOT committed.

# --- Required ---
MONDAY_TOKEN=your_monday_api_token_here
# YourLifeBroker "Leads" board (same board the Aircall->Monday service writes to)
MONDAY_BOARD_ID=18417923566

# --- Optional ---
MONDAY_GROUP_ID=
# Pin a Monday API version, e.g. 2024-10 (blank = account default)
MONDAY_API_VERSION=
# Only needed if the website is hosted on a DIFFERENT domain than this API
ALLOW_ORIGIN=
PORT=8080

# --- Column ID mapping ---
# Any COL_* left blank/unset is simply not written (no error). Only the columns
# you map get populated; everything is also captured in the Notes summary below.
#
# CONFIRMED on the YLB Leads board (from the ylb-monday-aircall service):
COL_PHONE=lead_phone
COL_STATUS=lead_status
MONDAY_STATUS_LABEL=New Lead
COL_SOURCE=text_mm4f2gw1
LEAD_SOURCE=Website Quote Form
# Long-text column — receives a full summary of every answer (coverage, state, age,
# gender, nicotine, email, phone). Recommended so nothing is lost even without
# a dedicated column per field:
COL_NOTES=long_text_mm4k9vaw

# OPTIONAL — only if you create/confirm dedicated columns for these web-only fields.
# Run the columns query in the README to get each ID, then fill in. Blank = skip.
COL_EMAIL=
COL_STATE=
COL_COVERAGE=
COL_AGE=
COL_GENDER=
COL_NICOTINE=

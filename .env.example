# Copy to .env for local dev:  cp .env.example .env
# In production these are set as Fly secrets, NOT committed.

# --- Required ---
MONDAY_TOKEN=your_monday_api_token_here
MONDAY_BOARD_ID=1234567890

# --- Optional ---
# Group/section ID to place new leads into (find with the columns query in README)
MONDAY_GROUP_ID=
# Pin a Monday API version, e.g. 2024-10 (leave blank to use the account default)
MONDAY_API_VERSION=
# Only needed if the website is hosted on a DIFFERENT domain than this API
ALLOW_ORIGIN=
# Local port
PORT=8080

# --- Column ID mapping (MUST match your board's column IDs) ---
# Defaults below are guesses — replace with the real IDs from your board.
COL_EMAIL=email
COL_PHONE=phone
COL_STATE=text_state
COL_COVERAGE=text_coverage
COL_AGE=numbers_age
COL_GENDER=text_gender
COL_NICOTINE=text_nicotine
# A status/dropdown column for lead stage (leave blank to skip)
COL_STATUS=
MONDAY_STATUS_LABEL=New Lead
